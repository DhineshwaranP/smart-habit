PORT=3000
HOST=0.0.0.0
DATABASE_PATH=./habits-data.json
JWT_SECRET=replace-with-a-long-random-secret

# Gmail / SMTP email notifications
# Leave false for in-app notifications only. Set true only after SMTP is configured.
EMAIL_DELIVERY_ENABLED=false
# For Gmail, create an App Password and use it here.
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
MAIL_FROM=youraddress@gmail.com
# Optional custom SMTP instead of Gmail defaults
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-gmail-app-password
