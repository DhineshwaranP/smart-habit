{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Smart Habit App",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "node",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*node server\\.js.*$",
          "endsPattern": "^.*Server is running locally at http://localhost:[0-9]+.*$"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
